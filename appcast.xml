    <item>
      <title>Version 1.0.5</title>
      <sparkle:version>5</sparkle:version>
      <sparkle:shortVersionString>1.0.5</sparkle:shortVersionString>
      <description><![CDATA[
        <ul>
          <li>Fixed keyboard arrow navigation jumping to oldest item in History tab</li>
          <li>Fixed app crash when deleting clipboard cards</li>
          <li>Improved image paste for terminal apps (Ghostty, Claude Code)</li>
          <li>Fixed non-ASCII characters in temp image filenames</li>
        </ul>
      ]]></description>
